  .hot-tag.white-glove { background: #F4ECD9; color: #8B6A1F; }
  .hot-tag.new-date, .hot-tag.verified-date { background: var(--alliance-blue); color: var(--spectrum-blue); }
  .hot-tag.other { background: var(--bg); color: var(--muted); }
