  .miss-form .row2 { display: grid; grid-template-columns: 1fr 90px; gap: 10px; }
  .miss-form textarea { min-height: 60px; resize: vertical; }
  .miss-form select optgroup { font-family: 'Montserrat', sans-serif; font-weight: 700; color: var(--spectrum-blue); }
