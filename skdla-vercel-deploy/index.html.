<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Station Health — AOX</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&family=Lora:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    color-scheme: light;
    --spectrum-blue: #052030;
    --killian-blue: #1882C7;
    --dental-blue: #4ABEEE;
    --lab-gold: #B3A369;
    --alliance-blue: #C3E8FA;
    --solutions-silver: #B0B7C3;
    --bg: #F4F7FA;
    --card: #FFFFFF;
    --ink: #052030;
    --muted: #4A5A6A;
    --hairline: #D9DEE4;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    background: var(--bg); color: var(--ink);
    font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 400;
  }
  body { padding: 22px 28px 32px; min-height: 100vh; font-size: 15px; }

  .brand-bar { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .brand-mark { width: 42px; height: 42px; flex-shrink: 0; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.05; }
  .brand-text .brand-name { font-weight: 800; letter-spacing: 0.06em; color: var(--spectrum-blue); font-size: 22px; }
  .brand-text .brand-sub { font-family: 'Lora', Georgia, serif; font-weight: 400; color: var(--killian-blue); font-size: 14px; margin-top: 3px; letter-spacing: 0.02em; }
  .top-actions { margin-left: auto; display: flex; gap: 10px; align-items: center; }
  .updated { font-size: 13px; color: var(--muted); font-family: 'Open Sans', sans-serif; }
  .live-dot {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: #16794d; margin-right: 6px; box-shadow: 0 0 0 0 rgba(22,121,77,0.6);
    animation: pulse 2s infinite;
  }
  .live-dot.stale { background: #b03b1b; animation: none; }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(22,121,77,0.6); }
    70% { box-shadow: 0 0 0 8px rgba(22,121,77,0); }
    100% { box-shadow: 0 0 0 0 rgba(22,121,77,0); }
  }

  /* Station tab strip */
  .tabs {
    display: flex; gap: 0; flex-wrap: wrap;
    background: var(--card);
    border: 2px solid var(--spectrum-blue);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .tab {
    flex: 1 1 auto; min-width: 120px;
    padding: 16px 18px; cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 15px; letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--spectrum-blue); background: transparent;
    border-right: 1px solid var(--hairline);
    text-align: center; transition: all 0.15s;
    user-select: none;
  }
  .tab:last-child { border-right: none; }
  .tab:hover { background: var(--alliance-blue); }
  .tab.active {
    background: var(--spectrum-blue); color: #fff;
    box-shadow: inset 0 -3px 0 var(--dental-blue);
  }

  .err-banner {
    display: none; margin-bottom: 14px; padding: 10px 14px;
    background: #fdeaea; border: 1px solid #e0a4a4; color: #8c1f1f;
    border-radius: 4px; font-family: 'Open Sans', sans-serif; font-size: 13px;
  }
  .err-banner.open { display: block; }

  .header-row { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: 16px; margin-bottom: 16px; }
  .title-card {
    display: flex; align-items: center; justify-content: center; text-align: center;
    padding: 26px 18px;
    background: linear-gradient(135deg, var(--spectrum-blue) 0%, #0A3550 100%);
    color: #fff; border: 2px solid var(--spectrum-blue); border-radius: 6px;
    position: relative; overflow: hidden;
  }
  .title-card::after { content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 4px; background: var(--dental-blue); }
  .title-card h1 { margin: 0; font-weight: 800; font-size: 40px; letter-spacing: 0.08em; text-transform: uppercase; }
  .title-card .subtitle { margin-top: 10px; font-family: 'Lora', Georgia, serif; font-weight: 400; font-size: 17px; color: var(--alliance-blue); letter-spacing: 0.04em; }

  .side-stack { display: flex; flex-direction: column; gap: 16px; }
  .pill {
    background: var(--card); border: 2px solid var(--spectrum-blue); border-radius: 6px;
    padding: 16px 20px; display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; transition: background 0.15s;
  }
  .pill:hover { background: var(--alliance-blue); }
  .pill .label { font-weight: 700; font-size: 17px; color: var(--spectrum-blue); letter-spacing: 0.02em; }
  .pill .count { font-weight: 800; font-size: 36px; color: var(--killian-blue); min-width: 40px; text-align: right; }

  .board { display: grid; grid-template-columns: minmax(0,1fr) 340px; gap: 16px; align-items: start; }
  .right-stack { display: flex; flex-direction: column; gap: 16px; }
  .panel { background: var(--card); border: 2px solid var(--spectrum-blue); border-radius: 6px; overflow: hidden; }

  table.hourly { width: 100%; border-collapse: collapse; font-family: 'Open Sans', sans-serif; }
  table.hourly thead th {
    background: var(--spectrum-blue); color: #fff; text-align: center; padding: 16px 12px;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 16px;
    letter-spacing: 0.08em; text-transform: uppercase;
    border-right: 1px solid rgba(255,255,255,0.15);
  }
  table.hourly thead th:last-child { border-right: none; }
  table.hourly thead th.hour-col   { width: 14%; }
  table.hourly thead th.actual-col { width: 18%; }
  table.hourly thead th.target-col { width: 18%; }
  table.hourly thead th.pct-col    { width: 50%; }
  table.hourly tbody td { padding: 14px 12px; text-align: center; font-size: 17px; border-bottom: 1px solid var(--hairline); border-right: 1px solid var(--hairline); background: #fff; }
  table.hourly tbody td:last-child { border-right: none; }
  table.hourly tbody tr:last-child td { border-bottom: none; }
  table.hourly tbody td.hour-cell { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 20px; color: var(--spectrum-blue); background: #F4F7FA; text-align: center; padding-left: 10px; padding-right: 10px; letter-spacing: 0.02em; cursor: pointer; user-select: none; transition: background 0.15s; }
  table.hourly tbody td.hour-cell:hover { background: var(--alliance-blue); }
  table.hourly tbody td.hour-cell .chev {
    display: inline-block; margin-right: 6px; transition: transform 0.2s;
    color: var(--killian-blue); font-size: 13px; vertical-align: middle;
  }
  table.hourly tbody tr.expanded td.hour-cell .chev { transform: rotate(90deg); }

  /* Quarter-hour sub-rows */
  table.hourly tbody tr.qrow { background: #FBFCFD; }
  table.hourly tbody tr.qrow td {
    padding: 10px 12px; font-size: 16px;
    border-bottom: 1px solid var(--hairline);
    background: #FBFCFD;
  }
  table.hourly tbody tr.qrow td.q-hour {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    color: var(--muted); text-align: center; font-size: 16px;
    background: #EFF2F6;
  }
  table.hourly tbody tr.qrow td.q-actual {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 22px; color: var(--spectrum-blue);
  }
  table.hourly tbody tr.qrow td.q-actual.over { color: #16794d; }
  table.hourly tbody tr.qrow td.q-actual.under { color: #b03b1b; }
  table.hourly tbody tr.qrow td.q-target {
    color: var(--muted); font-weight: 600; font-size: 18px;
  }
  table.hourly tbody tr.qrow td.q-pct { padding: 7px 18px; }
  table.hourly tbody tr.qrow td.q-pct .pct-bar { height: 26px; }
  table.hourly tbody tr.qrow td.q-pct .pct-bar .pct-label { font-size: 14px; }
  table.hourly tbody td.actual-cell { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 28px; color: var(--spectrum-blue); }
  table.hourly tbody td.actual-cell.over { color: #16794d; }
  table.hourly tbody td.actual-cell.under { color: #b03b1b; }
  table.hourly tbody td.target-cell { color: var(--muted); font-weight: 600; font-size: 22px; }
  table.hourly tbody td.pct-cell { padding: 10px 18px; text-align: left; position: relative; }

  /* Miss-reason affordance inside the % cell */
  .miss-action {
    margin-top: 6px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 11px;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--muted);
    cursor: pointer; user-select: none;
    transition: all 0.15s;
  }
  .miss-action:hover { border-color: var(--killian-blue); color: var(--killian-blue); background: var(--alliance-blue); }
  .miss-action.has-entries {
    background: #FCE4E4; border-color: #E0A4A4; color: #8C1F1F;
  }
  .miss-action.has-entries:hover { background: #F8D5D5; }
  .miss-action .ma-num { font-weight: 800; font-size: 12px; }
  table.hourly tbody tr.future td { opacity: 0.55; }
  table.hourly tbody tr.current td { background: var(--alliance-blue); }
  table.hourly tbody tr.current td.hour-cell { background: var(--dental-blue); color: #fff; }

  /* % completion bar */
  .pct-bar {
    position: relative;
    height: 34px;
    background: #ECEFF3;
    border-radius: 4px;
    overflow: hidden;
    width: 100%;
  }
  .pct-bar .pct-fill {
    position: absolute; left: 0; top: 0; bottom: 0;
    background: var(--solutions-silver);
    transition: width 0.3s;
  }
  .pct-bar.over .pct-fill { background: linear-gradient(90deg, #16794d, #2BA46B); }
  .pct-bar.under .pct-fill { background: linear-gradient(90deg, #B03B1B, #D55A33); }
  .pct-bar.partial .pct-fill { background: linear-gradient(90deg, var(--lab-gold), #D9C079); }
  .pct-bar.future .pct-fill { background: var(--hairline); }
  .pct-bar .pct-label {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 800; font-size: 16px;
    color: var(--spectrum-blue);
    letter-spacing: 0.04em;
    text-shadow: 0 0 4px rgba(255,255,255,0.85);
  }
  .pct-bar.future .pct-label { color: var(--muted); }

  .cumulative-card { background: var(--card); border: 2px solid var(--spectrum-blue); border-radius: 6px; overflow: hidden; }
  .cumulative-card .head { background: var(--spectrum-blue); color: #fff; text-align: center; padding: 16px 10px; font-weight: 800; font-size: 18px; letter-spacing: 0.08em; text-transform: uppercase; position: relative; }
  .cumulative-card .head::after { content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 3px; background: var(--dental-blue); }
  .cumulative-block { padding: 28px 12px; text-align: center; border-bottom: 1px solid var(--hairline); }
  .cumulative-block:last-child { border-bottom: none; }
  .cumulative-block .label { font-weight: 700; font-size: 16px; color: var(--spectrum-blue); letter-spacing: 0.06em; text-transform: uppercase; }
  .cumulative-block .number { font-weight: 800; font-size: 60px; color: var(--killian-blue); line-height: 1.05; margin-top: 8px; }
  .cumulative-block.target .number { color: var(--lab-gold); }
  .cumulative-block .delta { font-family: 'Open Sans', sans-serif; font-size: 14px; color: var(--muted); margin-top: 6px; }
  .cumulative-block.pct {
    background: var(--bg);
  }
  .cumulative-block.pct .number {
    font-size: 54px;
    transition: color 0.2s;
  }
  .cumulative-block.pct .number.over    { color: #16794d; }
  .cumulative-block.pct .number.partial { color: var(--lab-gold); }
  .cumulative-block.pct .number.under   { color: #b03b1b; }
  .cumulative-block.pct .number.future  { color: var(--solutions-silver); }

  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(5,32,48,0.5); align-items: center; justify-content: center; z-index: 100; }
  .modal-overlay.open { display: flex; }
  .modal { background: #fff; border: 2px solid var(--spectrum-blue); border-radius: 8px; width: min(440px, 90vw); overflow: hidden; }
  .modal-head { background: var(--spectrum-blue); color: #fff; padding: 12px 16px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 14px; }
  .modal-body { padding: 16px; }
  .modal-body .existing { margin-bottom: 12px; max-height: 180px; overflow-y: auto; }
  .modal-body .existing .item { padding: 8px 10px; background: var(--bg); border-left: 3px solid var(--killian-blue); margin-bottom: 6px; font-family: 'Lora', Georgia, serif; font-size: 13px; color: var(--ink); border-radius: 0 4px 4px 0; display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .modal-body .existing .item .meta { font-size: 10px; font-family: 'Open Sans', sans-serif; color: var(--muted); flex-shrink: 0; }
  .modal-body .existing .empty { font-family: 'Open Sans', sans-serif; font-size: 12px; color: var(--muted); font-style: italic; padding: 8px 0; }
  .modal-body textarea { width: 100%; min-height: 80px; border: 1px solid var(--hairline); border-radius: 4px; padding: 8px 10px; font-family: 'Open Sans', sans-serif; font-size: 13px; resize: vertical; }
  .modal-body textarea:focus { outline: none; border-color: var(--killian-blue); box-shadow: 0 0 0 2px var(--alliance-blue); }
  .modal-actions { padding: 12px 16px; display: flex; justify-content: flex-end; gap: 8px; background: #F4F7FA; border-top: 1px solid var(--hairline); }
  button.btn { font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; border-radius: 4px; padding: 8px 14px; cursor: pointer; border: 1px solid transparent; transition: all 0.15s; }
  button.btn.primary { background: var(--killian-blue); color: #fff; border-color: var(--killian-blue); }
  button.btn.primary:hover { background: var(--spectrum-blue); border-color: var(--spectrum-blue); }
  button.btn.ghost { background: transparent; color: var(--spectrum-blue); border-color: var(--solutions-silver); }
  button.btn.ghost:hover { background: var(--bg); }

  .loading { text-align: center; padding: 22px; color: var(--muted); font-family: 'Open Sans', sans-serif; font-size: 13px; }

  /* WIP banner */
  .wip-banner {
    background: linear-gradient(90deg, var(--alliance-blue) 0%, #fff 60%);
    border: 2px solid var(--killian-blue);
    border-radius: 6px;
    padding: 16px 22px;
    margin-bottom: 16px;
    display: flex; align-items: center; gap: 22px;
  }
  .wip-banner .wip-num {
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 56px;
    color: var(--killian-blue); line-height: 1;
  }
  .wip-banner .wip-label {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--spectrum-blue); font-size: 18px;
  }
  .wip-banner .wip-sub {
    font-family: 'Lora', Georgia, serif; font-style: italic;
    color: var(--muted); font-size: 15px; margin-top: 4px;
  }
  .wip-banner.empty .wip-num { color: var(--solutions-silver); }

  /* Lower row removed — content now lives in .right-stack */
  .section-card {
    background: var(--card); border: 2px solid var(--spectrum-blue);
    border-radius: 6px; overflow: hidden;
  }
  .section-card .head {
    background: var(--spectrum-blue); color: #fff;
    padding: 14px 18px; font-family: 'Montserrat', sans-serif;
    font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 17px; position: relative;
    display: flex; justify-content: space-between; align-items: center;
  }
  .section-card .head::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 0;
    height: 3px; background: var(--dental-blue);
  }
  .section-card .head .badge {
    font-size: 13px; background: var(--dental-blue); color: var(--spectrum-blue);
    padding: 3px 12px; border-radius: 999px; font-weight: 800;
  }

  /* Tech leaderboard */
  .tech-list { padding: 8px 0; }
  .tech-row {
    display: grid; grid-template-columns: 36px 1fr auto;
    align-items: center; padding: 12px 18px;
    border-bottom: 1px solid var(--hairline);
    gap: 12px;
  }
  .tech-row:last-child { border-bottom: none; }
  .tech-rank {
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 18px;
    color: var(--lab-gold); text-align: center;
  }
  .tech-row.r-1 .tech-rank { color: var(--lab-gold); }
  .tech-row.r-2 .tech-rank { color: var(--solutions-silver); }
  .tech-row.r-3 .tech-rank { color: #B8743A; }
  .tech-name {
    font-family: 'Open Sans', sans-serif; font-size: 16px; color: var(--ink);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .tech-count {
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 22px;
    color: var(--killian-blue); min-width: 36px; text-align: right;
  }
  .empty-state {
    text-align: center; padding: 28px 16px;
    color: var(--muted); font-family: 'Lora', Georgia, serif;
    font-style: italic; font-size: 15px;
  }

  /* Out-of-hours tag */
  .ooh-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 14px;
    background: var(--lab-gold); color: #fff;
    border-radius: 999px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 13px;
    letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer; user-select: none;
    transition: filter 0.15s;
  }
  .ooh-tag:hover { filter: brightness(0.92); }
  .ooh-tag.empty { background: var(--solutions-silver); cursor: default; }
  .ooh-tag .num {
    background: rgba(255,255,255,0.25);
    padding: 2px 10px; border-radius: 999px;
    font-weight: 800; font-size: 14px;
  }

  /* OOH modal extras */
  .ooh-table {
    width: 100%; border-collapse: collapse;
    font-family: 'Open Sans', sans-serif; font-size: 13px;
  }
  .ooh-table thead th {
    background: var(--spectrum-blue); color: #fff;
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 8px 12px; text-align: left;
  }
  .ooh-table thead th:last-child { text-align: right; }
  .ooh-table tbody td {
    padding: 8px 12px; border-bottom: 1px solid var(--hairline);
  }
  .ooh-table tbody tr:last-child td { border-bottom: none; }
  .ooh-table tbody td.hr-cell {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    color: var(--spectrum-blue); white-space: nowrap;
  }
  .ooh-table tbody td.n-cell {
    text-align: right; font-family: 'Montserrat', sans-serif;
    font-weight: 700; color: var(--killian-blue);
  }
  .ooh-section-head {
    padding: 6px 12px;
    background: var(--alliance-blue);
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 11px;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--spectrum-blue);
  }

  /* Hot list */
  .hot-list { padding: 0; }
  .hot-row {
    padding: 14px 18px; border-bottom: 1px solid var(--hairline);
    display: grid; grid-template-columns: auto auto 1fr auto; gap: 12px;
    align-items: center;
    cursor: pointer; transition: background 0.15s;
  }
  .hot-row:hover { background: var(--bg); }
  .hot-row.expanded { background: var(--alliance-blue); }

  .hot-detail {
    padding: 14px 20px 18px;
    border-bottom: 1px solid var(--hairline);
    background: #FBFCFD;
    font-family: 'Open Sans', sans-serif;
    font-size: 13px;
    color: var(--ink);
  }
  .hot-detail .grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 14px;
  }
  .hot-detail .grid .k {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .hot-detail .grid .v {
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    color: var(--ink);
  }
  .hot-detail .grid .v.bold { font-weight: 700; color: var(--spectrum-blue); }
  .hot-detail .grid .v.warn { color: #8C1F1F; font-weight: 700; }
  .hot-detail .full-note {
    margin-top: 10px; padding: 10px 12px;
    background: #fff; border-left: 3px solid var(--lab-gold);
    font-family: 'Lora', Georgia, serif; font-size: 14px;
    color: var(--ink); line-height: 1.5; border-radius: 0 4px 4px 0;
  }
  .hot-row:last-child { border-bottom: none; }

  /* Miss-reason modal */
  .modal.miss-modal { width: min(560px, 92vw); }
  .miss-stat {
    display: flex; gap: 22px; padding: 12px 18px;
    background: var(--bg);
    border-bottom: 1px solid var(--hairline);
    font-family: 'Open Sans', sans-serif;
  }
  .miss-stat .v {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800; font-size: 18px; color: var(--spectrum-blue);
  }
  .miss-stat .v.miss { color: #b03b1b; }
  .miss-stat .l {
    font-size: 11px; color: var(--muted);
    letter-spacing: 0.06em; text-transform: uppercase;
    font-family: 'Montserrat', sans-serif; font-weight: 700;
  }
  .miss-existing { padding: 10px 18px; max-height: 180px; overflow-y: auto; }
  .miss-existing .empty {
