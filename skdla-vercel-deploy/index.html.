<script>
(() => {
  const SUPABASE_URL = 'https://asdunkqodixbhbohxtuq.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_egid5scBHSz-8we3LiurOw_SpmvJD9u';
  const BUSINESS_UNIT = 'AOX';
  const TZ = 'America/Los_Angeles';   // Pacific (PST/PDT)
  const SHIFT_START = 6;
  const SHIFT_END = 20;   // 6am – 8pm window (14 hourly rows)
  const REFRESH_MS = 60000;

  // ---------- Helpers ----------
  const fmtHour = (h) => {
    const ampm = h >= 12 ? 'pm' : 'am';
    return (((h + 11) % 12) + 1) + ampm;
  };
  const fmtHourMin = (h, m) => {
    const ampm = h >= 12 ? 'pm' : 'am';
    const display = ((h + 11) % 12) + 1;
    return display + ':' + String(m).padStart(2, '0') + ampm;
  };
  const showErr = (msg) => {
    const el = document.getElementById('err');
    el.textContent = msg;
    el.classList.add('open');
    document.getElementById('live-dot').classList.add('stale');
  };
  const clearErr = () => {
    document.getElementById('err').classList.remove('open');
    document.getElementById('live-dot').classList.remove('stale');
  };
  const getNowLocalHour = () => parseInt(
    new Intl.DateTimeFormat('en-US', { timeZone: TZ, hour: 'numeric', hour12: false }).format(new Date()), 10);
  const getNowLocalMinute = () => parseInt(
    new Intl.DateTimeFormat('en-US', { timeZone: TZ, minute: 'numeric' }).format(new Date()), 10);
  const fmtLongDate = () =>
    new Intl.DateTimeFormat('en-US', { timeZone: TZ, weekday: 'long', month: 'short', day: 'numeric' }).format(new Date());
  const fmtTimestamp = () =>
    new Intl.DateTimeFormat('en-US', { timeZone: TZ, hour: 'numeric', minute: '2-digit', hour12: true }).format(new Date());

  async function rpc(fnName, body) {
    const url = SUPABASE_URL + '/rest/v1/rpc/' + fnName;
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + SUPABASE_KEY,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(body || {}),
    });
    if (!res.ok) {
      const text = await res.text().catch(() => '');
      throw new Error(`RPC ${fnName} ${res.status}: ${text}`);
    }
    return res.json();
  }

  // ---------- State ----------
  const state = {
    stations: [],
    station: null,
    target: 0,
    hourly: {},
    log: { near_misses: [], ideas: [] },
    countMethod: 'distinct_pan',
    wip: 0,
    hotList: [],
    techs: [],
    ooh: { total: 0, rows: [] },
    quarter: {},          // { "8-0": 2, "8-15": 1, ... }
    expanded: new Set(),  // hours expanded into quarter view
    expandedHot: new Set(),  // hot list case_numbers expanded
    missLog: [],          // today's miss-log rows
    missReasons: { common: [], station: [] }, // dropdown options
    missReasonsForStation: null, // cache key (station name) for the loaded list
  };

  // Persist last-selected station
  function saveStation(s) { try { localStorage.setItem('sk_station', s); } catch(e){} }
  function loadStation()  { try { return localStorage.getItem('sk_station'); } catch(e){ return null; } }

  // ---------- Tabs ----------
  function renderTabs() {
    const tabsEl = document.getElementById('tabs');
    tabsEl.innerHTML = '';
    state.stations.forEach(s => {
      const div = document.createElement('div');
      div.className = 'tab' + (s.station === state.station ? ' active' : '');
      div.textContent = s.station;
      div.addEventListener('click', () => {
        if (state.station === s.station) return;
        state.station = s.station;
        saveStation(s.station);
        renderTabs();
        load();
      });
      tabsEl.appendChild(div);
    });
  }

  // ---------- Render ----------
  function renderHeader() {
    document.getElementById('today-label').textContent = fmtLongDate();
    document.getElementById('updated-stamp').textContent = 'Updated ' + fmtTimestamp();
    document.getElementById('station-title').textContent = state.station || 'Station Health';
    document.getElementById('count-method').textContent =
      state.countMethod === 'distinct_case' ? 'cases entered'
      : state.countMethod === 'distinct_pan' ? 'cases counted'
      : 'step finishes';
  }

  function renderHourly() {
    const tbody = document.getElementById('hour-body');
    const nowHour = getNowLocalHour();
    const nowMin  = getNowLocalMinute();
    const hourlyTarget = state.target / (SHIFT_END - SHIFT_START);
    let cumActual = 0, cumTarget = 0;
    const rows = [];
    const quarterTarget = hourlyTarget / 4;

    function buildPctCell(actual, tgt, isFuture) {
      const pct = tgt > 0 ? (actual / tgt) * 100 : 0;
      const pctDisplay = isFuture ? '—' : Math.round(pct) + '%';
      const fillWidth = Math.min(100, pct);
      let barClass = 'future';
      if (!isFuture) {
        if (pct >= 100) barClass = 'over';
        else if (pct >= 67) barClass = 'partial';
        else barClass = 'under';
      }
      return `<div class="pct-bar ${barClass}"><div class="pct-fill" style="width:${fillWidth}%"></div><div class="pct-label">${pctDisplay}</div></div>`;
    }

    for (let h = SHIFT_START; h < SHIFT_END; h++) {
      const actual = state.hourly[h] ?? 0;
      cumActual += actual;
      const isPast = h < nowHour;
      const isCurrent = h === nowHour;
      if (isPast || isCurrent) cumTarget += hourlyTarget;
      const isFuture = h > nowHour;
      const aClass = isPast ? (actual >= hourlyTarget ? 'over' : 'under') : '';
      const trClass = (isCurrent ? 'current ' : (isFuture ? 'future ' : '')) + (state.expanded.has(h) ? 'expanded' : '');

      const pctCell = buildPctCell(actual, hourlyTarget, isFuture);

      // Miss-reason affordance for past hours (and current)
      let missAction = '';
      if (!isFuture) {
        const entries = (state.missLog || []).filter(ml => ml.hour === h);
        const entryCount = entries.length;
        const totalCases = entries.reduce((s, e) => s + (e.miss_count || 0), 0);
        const hasEntries = entryCount > 0;
        const label = hasEntries
          ? `<span class="ma-num">${entryCount}</span> reason${entryCount===1?'':'s'} · ${totalCases} cases`
          : '+ Log miss reason';
        missAction = `<div class="miss-action ${hasEntries?'has-entries':''}" data-miss-hour="${h}">${label}</div>`;
      }

      rows.push(`
        <tr class="hour-row ${trClass}" data-hour="${h}">
          <td class="hour-cell" data-hour="${h}"><span class="chev">▶</span>${fmtHour(h)}</td>
          <td class="actual-cell ${aClass}">${actual}</td>
          <td class="target-cell">${hourlyTarget % 1 === 0 ? hourlyTarget : hourlyTarget.toFixed(1)}</td>
          <td class="pct-cell">${pctCell}${missAction}</td>
        </tr>`);

      // Quarter-hour expansion
      if (state.expanded.has(h)) {
        const minutes = [0, 15, 30, 45];
        for (const mn of minutes) {
          const qActual = state.quarter[h + '-' + mn] ?? 0;
          // A quarter is "past" if its END has passed
          const quarterEndHour = mn + 15 >= 60 ? h + 1 : h;
          const quarterEndMin  = (mn + 15) % 60;
          const isQFuture =
            quarterEndHour > nowHour ||
            (quarterEndHour === nowHour && quarterEndMin > nowMin);
          const isQPast = !isQFuture && (h < nowHour || (h === nowHour && mn + 15 <= nowMin));
          const qaClass = isQPast ? (qActual >= quarterTarget ? 'over' : 'under') : '';
          const qPctCell = buildPctCell(qActual, quarterTarget, isQFuture);
          const label = fmtHourMin(h, mn);
          rows.push(`
            <tr class="qrow" data-parent-hour="${h}">
              <td class="q-hour">${label}</td>
              <td class="q-actual ${qaClass}">${qActual}</td>
              <td class="q-target">${quarterTarget % 1 === 0 ? quarterTarget : quarterTarget.toFixed(2)}</td>
              <td class="q-pct">${qPctCell}</td>
            </tr>`);
        }
      }
    }
    tbody.innerHTML = rows.join('');

    // Wire up click handlers on hour cells
    tbody.querySelectorAll('td.hour-cell').forEach(cell => {
      cell.addEventListener('click', () => {
        const h = parseInt(cell.dataset.hour, 10);
        if (state.expanded.has(h)) state.expanded.delete(h);
        else state.expanded.add(h);
        renderHourly();
      });
    });

    tbody.querySelectorAll('.miss-action').forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        openMissModal(parseInt(el.dataset.missHour, 10));
      });
    });

    document.getElementById('cum-actual').textContent = cumActual;
    document.getElementById('cum-target').textContent = Math.round(cumTarget * 10) / 10;
    document.getElementById('daily-target-display').textContent = state.target;
    const delta = cumActual - cumTarget;
    const deltaEl = document.getElementById('cum-actual-delta');
    if (cumTarget > 0) {
      const sign = delta >= 0 ? '+' : '';
      deltaEl.innerHTML = `<span style="color:${delta>=0?'#16794d':'#b03b1b'};font-weight:600">${sign}${(Math.round(delta*10)/10)}</span> vs pace`;
    } else {
      deltaEl.innerHTML = '&nbsp;';
    }

    // Cumulative % Complete
    const pctEl = document.getElementById('cum-pct');
    const pctSub = document.getElementById('cum-pct-sub');
    pctEl.classList.remove('over', 'partial', 'under', 'future');
    if (cumTarget > 0) {
      const pct = (cumActual / cumTarget) * 100;
      pctEl.textContent = Math.round(pct) + '%';
      if (pct >= 100)      pctEl.classList.add('over');
      else if (pct >= 67)  pctEl.classList.add('partial');
      else                 pctEl.classList.add('under');
      pctSub.textContent = 'of pace';
    } else {
      pctEl.textContent = '—';
      pctEl.classList.add('future');
      pctSub.textContent = 'shift not started';
    }
  }

  function renderSide() {
    const log = state.log || { near_misses: [], ideas: [] };
    document.getElementById('near-miss-count').textContent = (log.near_misses || []).length;
    document.getElementById('ideas-count').textContent = (log.ideas || []).length;
  }

  function renderWip() {
    const banner = document.getElementById('wip-banner');
    const num = document.getElementById('wip-num');
    const sub = document.getElementById('wip-sub');
    num.textContent = state.wip;
    if (state.wip === 0) {
      banner.classList.add('empty');
      sub.textContent = 'no cases waiting at this station';
    } else {
      banner.classList.remove('empty');
      const ratio = state.target > 0 ? (state.wip / state.target) : 0;
      const tone = ratio < 0.5 ? 'queue is light' : ratio < 1 ? 'within a day of capacity' : 'backlog exceeds daily target';
      sub.textContent = 'cases currently parked at this station — ' + tone;
    }
  }

  function renderTechs() {
    const list = document.getElementById('tech-list');
    const badge = document.getElementById('techs-badge');
    badge.textContent = state.techs.length;
    if (state.techs.length === 0) {
      list.innerHTML = '<div class="empty-state">No finishes logged yet today.</div>';
      return;
    }
    list.innerHTML = state.techs.map((t, i) => {
      const safe = (t.tech_name || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
      return `<div class="tech-row r-${i+1}"><div class="tech-rank">${i+1}</div><div class="tech-name">${safe}</div><div class="tech-count">${t.n}</div></div>`;
    }).join('');
  }

  function renderOoh() {
    const tag = document.getElementById('ooh-tag');
    const num = document.getElementById('ooh-num');
    const total = state.ooh.total || 0;
    num.textContent = total;
    if (total === 0) tag.classList.add('empty'); else tag.classList.remove('empty');
  }

  function renderOohModal() {
    const body = document.getElementById('ooh-body');
    const rows = state.ooh.rows || [];
    if (rows.length === 0) {
      body.innerHTML = '<div class="empty-state" style="padding:32px 16px">No out-of-hours work today.</div>';
      return;
    }
    // Split into pre-shift (<6) and post-shift (>=18)
    const pre  = rows.filter(r => r.hr <  SHIFT_START);
    const post = rows.filter(r => r.hr >= SHIFT_END);
    const renderSection = (label, list, totalLabel) => {
      if (list.length === 0) return '';
      const total = list.reduce((s,r) => s + (r.n || 0), 0);
      const trs = list.map(r => `
        <tr>
          <td class="hr-cell">${fmtHour(r.hr)}</td>
          <td>${(r.station || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</td>
          <td class="n-cell">${r.n}</td>
        </tr>`).join('');
      return `
        <div class="ooh-section-head">${label} &middot; ${total} cases</div>
        <table class="ooh-table">
          <thead><tr><th style="width:80px">Hour</th><th>Station</th><th style="width:80px">Cases</th></tr></thead>
          <tbody>${trs}</tbody>
        </table>`;
    };
    body.innerHTML =
      renderSection('Before Shift (12am – 6am)', pre) +
      renderSection('After Shift (6pm – 12am)', post);
  }

  document.getElementById('ooh-tag').addEventListener('click', () => {
    if ((state.ooh.total || 0) === 0) return;
    renderOohModal();
    document.getElementById('ooh-overlay').classList.add('open');
  });
  document.getElementById('ooh-close').addEventListener('click', () => {
    document.getElementById('ooh-overlay').classList.remove('open');
  });
  document.getElementById('ooh-overlay').addEventListener('click', (e) => {
    if (e.target.id === 'ooh-overlay') {
      document.getElementById('ooh-overlay').classList.remove('open');
    }
  });

  function renderHotList() {
    const list = document.getElementById('hot-list');
    const badge = document.getElementById('hot-badge');
    badge.textContent = state.hotList.length;
    if (state.hotList.length === 0) {
      list.innerHTML = '<div class="empty-state">Nothing hot at this station.</div>';
      return;
    }
    const esc = s => String(s ?? '—').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
    const fmtDateShort = d => d ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(new Date(d)) : '—';
    const fmtDateTime = d => d ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true, timeZone: TZ }).format(new Date(d)) : '—';
    const fmtSeconds = s => {
      if (s == null) return '—';
      const sec = parseInt(s, 10);
      if (sec < 60) return sec + 's';
      if (sec < 3600) return Math.round(sec / 60) + 'm';
      const hrs = sec / 3600;
      if (hrs < 24) return hrs.toFixed(1) + 'h';
      return (hrs / 24).toFixed(1) + 'd';
    };
    const now = new Date();

    list.innerHTML = state.hotList.map(h => {
      const reason = (h.reason || 'other').toString();
      const tagClass = reason.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const dueRaw = h['Doctor Due Date'];
      let dueStr = '', dueClass = '';
      if (dueRaw) {
        const due = new Date(dueRaw);
        dueStr = 'Due ' + fmtDateShort(dueRaw);
        if (due < now) { dueClass = 'overdue'; dueStr = '⚠ ' + dueStr; }
      }
      const step = esc(h['Current Step']);
      const isExpanded = state.expandedHot.has(h.case_number);

      // Build expanded detail
      let detail = '';
      if (isExpanded) {
        const patient = [h['Patient First Name'], h['Patient Last Name']].filter(Boolean).join(' ') || '—';
        const reqOut = h['Required Out Of Lab Date'];
        const isOverdue = (h['Doctor Due Date'] && new Date(h['Doctor Due Date']) < now);
        const onHold = h['Hold Flag'] === 1;
        const shipped = !!h['Ship Date'];

        let rows = [
          ['Patient', esc(patient), 'bold'],
          ['Account', esc(h['Account Number']), ''],
          ['Product', esc(h['Primary Product']), ''],
          ['Current Step', esc(h['Current Step']), 'bold'],
          ['Doctor Due', esc(fmtDateShort(h['Doctor Due Date'])), isOverdue ? 'warn' : ''],
          ['Required Out of Lab', esc(fmtDateShort(reqOut)), ''],
          ['Case Status', esc(h['Case Status']), ''],
        ];
        if (onHold) {
          rows.push(['On Hold', `${h['Hold Days'] || 0} days · ${esc(h['Hold Reason'])}`, 'warn']);
        }
        if (shipped) {
          rows.push(['Shipped', fmtDateShort(h['Ship Date']) + ' · ' + esc(h['Carrier']) + ' · ' + esc(h['Tracking Number']), '']);
        }
        rows.push(['Hot list status', esc(h.status), '']);
        rows.push(['Added by', esc(h.added_by) + ' · ' + fmtDateTime(h.created_at), '']);
        if (h.accepted_by) {
          rows.push(['Accepted by', esc(h.accepted_by) + ' · ' + fmtDateTime(h.accepted_at), '']);
        }
        if (h['Hubspot Ticket ID']) {
          rows.push(['Hubspot Ticket', esc(h['Hubspot Ticket ID']), '']);
        }

        const gridHtml = rows.map(([k, v, cls]) =>
          `<div class="k">${k}</div><div class="v ${cls}">${v}</div>`).join('');

        const fullNote = h.note ? `<div class="full-note">${esc(h.note)}</div>` : '';
        detail = `<div class="hot-detail"><div class="grid">${gridHtml}</div>${fullNote}</div>`;
      }

      return `<div class="hot-row ${isExpanded ? 'expanded' : ''}" data-case="${esc(h.case_number)}">
        <div class="hot-case">${esc(h.case_number)}</div>
        <div class="hot-tag ${tagClass}">${esc(reason)}</div>
        <div class="hot-meta">${step}</div>
        <div class="hot-due ${dueClass}">${dueStr}</div>
      </div>${detail}`;
    }).join('');

    // Click to expand/collapse
    list.querySelectorAll('.hot-row').forEach(row => {
      row.addEventListener('click', () => {
        const cn = row.dataset.case;
        if (state.expandedHot.has(cn)) state.expandedHot.delete(cn);
        else state.expandedHot.add(cn);
        renderHotList();
      });
    });
  }

  // ---------- Modal ----------
  let modalField = null;
  function openModal(field) {
    modalField = field;
    const log = state.log || { near_misses: [], ideas: [] };
    const items = log[field] || [];
    document.getElementById('modal-title').textContent =
      (field === 'near_misses' ? 'Near Misses' : 'Ideas') + ' — ' + state.station;
    const ex = document.getElementById('modal-existing');
    if (items.length === 0) {
      ex.innerHTML = '<div class="empty">Nothing logged yet.</div>';
    } else {
      ex.innerHTML = items.map(it => {
        const time = it.at
          ? new Intl.DateTimeFormat('en-US', { timeZone: TZ, hour: 'numeric', minute: '2-digit', hour12: true }).format(new Date(it.at))
          : '';
        const text = (it.text || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
        return `<div class="item"><span>${text}</span><span class="meta">${time}</span></div>`;
      }).join('');
    }
    document.getElementById('modal-input').value = '';
    document.getElementById('modal-overlay').classList.add('open');
    setTimeout(() => document.getElementById('modal-input').focus(), 50);
  }
  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    modalField = null;
  }
  async function addItem() {
    const txt = document.getElementById('modal-input').value.trim();
    if (!txt || !modalField || !state.station) return;
    try {
      const updated = await rpc('station_health_add_item', {
        p_station: state.station, p_business_unit: BUSINESS_UNIT,
        p_field: modalField, p_text: txt, p_tz: TZ,
      });
      if (updated) {
        state.log = { near_misses: updated.near_misses || [], ideas: updated.ideas || [] };
      }
      renderSide();
      openModal(modalField);
      clearErr();
    } catch (e) {
      console.error(e);
      showErr('Could not save: ' + e.message);
    }
  }

  // ---------- Miss-reason modal ----------
  let currentMissHour = null;
  async function ensureReasonsLoaded() {
    if (state.missReasonsForStation === state.station) return;
    const list = await rpc('miss_reasons_get', { p_business_unit: BUSINESS_UNIT, p_station: state.station });
    const common = (list || []).filter(r => r.scope === 'common');
    const station = (list || []).filter(r => r.scope === 'station');
    state.missReasons = { common, station };
    state.missReasonsForStation = state.station;
    const sel = document.getElementById('miss-reason');
    sel.innerHTML = '';
    if (common.length) {
      const og = document.createElement('optgroup');
      og.label = 'Common';
      common.forEach(r => { const o = document.createElement('option'); o.value = r.reason; o.textContent = r.reason; og.appendChild(o); });
      sel.appendChild(og);
    }
    if (station.length) {
      const og = document.createElement('optgroup');
      og.label = state.station + '-specific';
      station.forEach(r => { const o = document.createElement('option'); o.value = r.reason; o.textContent = r.reason; og.appendChild(o); });
      sel.appendChild(og);
    }
  }

  function renderMissExisting() {
    const cont = document.getElementById('miss-existing');
    const entries = (state.missLog || []).filter(ml => ml.hour === currentMissHour);
    if (entries.length === 0) {
      cont.innerHTML = '<div class="empty">Nothing logged for this hour yet.</div>';
      return;
    }
    const fmtTime = d => new Intl.DateTimeFormat('en-US', { timeZone: TZ, hour: 'numeric', minute: '2-digit', hour12: true }).format(new Date(d));
    const esc = s => String(s ?? '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
    cont.innerHTML = entries.map(e => {
      const note = e.notes ? `<div class="note-text">${esc(e.notes)}</div>` : '';
      return `<div class="row">
        <span class="badge-count">${e.miss_count}</span>
        <span class="reason-text">${esc(e.reason)}</span>
        <span class="meta">${fmtTime(e.created_at)}</span>
        <button class="del" data-id="${esc(e.id)}" title="Delete">×</button>
        ${note}
      </div>`;
    }).join('');
    cont.querySelectorAll('button.del').forEach(b => {
      b.addEventListener('click', async (ev) => {
        ev.stopPropagation();
        const id = b.dataset.id;
        try {
          await rpc('miss_log_delete', { p_id: id });
          state.missLog = state.missLog.filter(x => x.id !== id);
          renderMissExisting();
          renderHourly();
        } catch (e) { console.error(e); showErr('Could not delete: ' + e.message); }
      });
    });
  }

  async function openMissModal(hour) {
    currentMissHour = hour;
    document.getElementById('miss-title').textContent = 'Miss Reasons · ' + fmtHour(hour);
    const actual = state.hourly[hour] ?? 0;
    const tgt = state.target / (SHIFT_END - SHIFT_START);
    const miss = Math.max(0, Math.round((tgt - actual) * 10) / 10);
    const stat = document.getElementById('miss-stat');
    stat.innerHTML = `
      <div><div class="l">Actual</div><div class="v">${actual}</div></div>
      <div><div class="l">Target</div><div class="v">${tgt % 1 === 0 ? tgt : tgt.toFixed(1)}</div></div>
      <div><div class="l">Missed</div><div class="v miss">-${miss}</div></div>
      <div><div class="l">Station</div><div class="v">${state.station || ''}</div></div>`;
    document.getElementById('miss-notes').value = '';
    document.getElementById('miss-count').value = Math.max(1, Math.round(miss) || 1);
    try { await ensureReasonsLoaded(); } catch (e) { console.error(e); }
    renderMissExisting();
    document.getElementById('miss-overlay').classList.add('open');
  }
  function closeMissModal() {
    document.getElementById('miss-overlay').classList.remove('open');
    currentMissHour = null;
  }
  async function addMiss() {
    if (currentMissHour == null) return;
    const reason = document.getElementById('miss-reason').value;
    const count = parseInt(document.getElementById('miss-count').value, 10) || 1;
    const notes = document.getElementById('miss-notes').value.trim();
    if (!reason) return;
    try {
      const res = await rpc('miss_log_add', {
        p_business_unit: BUSINESS_UNIT, p_station: state.station,
        p_hour: currentMissHour, p_reason: reason,
        p_miss_count: count, p_notes: notes || null,
        p_logged_by: null, p_tz: TZ,
      });
      // optimistic add
      state.missLog.push({
        id: res.id, hour: currentMissHour, reason, miss_count: count,
        notes: notes || null, created_at: new Date().toISOString(),
      });
      document.getElementById('miss-notes').value = '';
      document.getElementById('miss-count').value = 1;
      renderMissExisting();
      renderHourly();
      clearErr();
    } catch (e) {
      console.error(e); showErr('Could not save: ' + e.message);
    }
  }

  document.getElementById('miss-close').addEventListener('click', closeMissModal);
  document.getElementById('miss-add').addEventListener('click', addMiss);
  document.getElementById('miss-overlay').addEventListener('click', (e) => {
    if (e.target.id === 'miss-overlay') closeMissModal();
  });

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('modal-add').addEventListener('click', addItem);
  document.getElementById('modal-overlay').addEventListener('click', (e) => {
    if (e.target.id === 'modal-overlay') closeModal();
  });
  document.getElementById('near-miss-pill').addEventListener('click', () => openModal('near_misses'));
  document.getElementById('ideas-pill').addEventListener('click', () => openModal('ideas'));

  // ---------- Load ----------
  async function loadStations() {
    const list = await rpc('station_health_list', { p_business_unit: BUSINESS_UNIT });
    state.stations = (list || []).map(r => ({ station: r.station, dept: r.target_dept_name, order: r.display_order }));
    if (!state.station) {
      state.station = loadStation() || (state.stations[0] && state.stations[0].station) || null;
    }
    renderTabs();
  }

  async function load() {
    if (!state.station) return;
    // Resilient: each fetch isolated so one failure doesn't blank the rest
    let mainErr = null, oohErr = null;
    const [mainRes, oohRes] = await Promise.all([
      rpc('station_health_get', { p_business_unit: BUSINESS_UNIT, p_station: state.station, p_tz: TZ })
        .catch(e => { mainErr = e; return null; }),
      rpc('station_health_out_of_hours_aox', { p_tz: TZ, p_shift_start: SHIFT_START, p_shift_end: SHIFT_END })
        .catch(e => { oohErr = e; return null; }),
    ]);

    if (mainRes) {
      state.target = parseFloat(mainRes.target) || 0;
      state.hourly = {};
      (mainRes.hourly || []).forEach(r => { state.hourly[r.hr] = r.n; });
      state.quarter = {};
      (mainRes.hourly_15min || []).forEach(r => { state.quarter[r.hr + '-' + r.mn] = r.n; });
      state.log = mainRes.log
        ? { near_misses: mainRes.log.near_misses || [], ideas: mainRes.log.ideas || [] }
        : { near_misses: [], ideas: [] };
      state.countMethod = mainRes.count_method || 'distinct_pan';
      state.wip = parseInt(mainRes.wip, 10) || 0;
      state.hotList = mainRes.hot_list || [];
      state.techs = mainRes.techs || [];
      state.missLog = mainRes.miss_log || [];
    }
    if (oohRes && typeof oohRes === 'object') {
      state.ooh = { total: parseInt(oohRes.total, 10) || 0, rows: oohRes.rows || [] };
    }

    if (mainErr) {
      console.error(mainErr);
      showErr('Live data unavailable: ' + mainErr.message);
    } else if (oohErr) {
      // Don't blank the whole page if only OOH failed
      console.error(oohErr);
      const dot = document.getElementById('live-dot');
      dot.classList.add('stale');
      const stamp = document.getElementById('updated-stamp');
      stamp.textContent = 'Out-of-hours stale';
    } else {
      clearErr();
    }
    renderHeader();
    renderHourly();
    renderSide();
    renderWip();
    renderTechs();
    renderHotList();
    renderOoh();
  }

  async function init() {
    try {
      await loadStations();
      await load();
    } catch (e) {
      console.error(e);
      showErr('Failed to initialise: ' + e.message);
    }
  }

  init();
  setInterval(load, REFRESH_MS);
})();
</script>
</body>
</html>
